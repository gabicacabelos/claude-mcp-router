# ─────────────────────────────────────────────
# INDIVIDRA MCP ROUTER — Variables de entorno
# Copiá este archivo a .env y completá los valores
# NUNCA commitees .env al repositorio
# ─────────────────────────────────────────────

# Gemini API (compresión primaria) — FREE tier
# Obtener en: https://aistudio.google.com/apikey
GEMINI_API_KEY=tu_clave_gemini_aqui

# Groq API (clasificación de intent) — FREE tier
# Obtener en: https://console.groq.com/keys
GROQ_API_KEY=tu_clave_groq_aqui

# OpenRouter (fallback opcional) — tiene free models
# Obtener en: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ─────────────────────────────────────────────
# Configuración opcional (defaults funcionales)
# ─────────────────────────────────────────────

# Directorio para la base de datos de caché
CACHE_DB_PATH=./cache/router_cache.db

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
